# ============================================================
# Finance Tweet Analyzer — 环境变量模板
# ============================================================
# 复制本文件为 .env 并填入真实值：
#   cp .env.example .env
#
# 所有敏感信息（密钥、密码、Token）必须且只能通过 .env 注入，
# 代码中不包含任何硬编码凭据。
# ============================================================

# ----- Database -----
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/finance_tweets
# Tests perform destructive schema setup/teardown; this database name must end in _test.
TEST_DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/finance_tweets_test

# ----- OpenRouter LLM -----
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HTTP_PROXY=

# ----- Models -----
SIGNAL_MODEL=qwen/qwen3.7-plus
REPORT_MODEL=qwen/qwen3.7-max

# ----- LangSmith (optional) -----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finance-tweet-analyzer
LANGSMITH_TRACING=false

# ----- Scheduler -----
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=10

# ----- Redis & Celery -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_PREDICTION_INTERVAL_MINUTES=5

# ----- RAG / Vector store -----
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_db
# When using Zilliz Cloud / Milvus:
# VECTOR_BACKEND=milvus
# MILVUS_URI=https://your-cluster-public-endpoint.cloud.zilliz.com
# MILVUS_TOKEN=your-zilliz-api-key
# MILVUS_DB_NAME=default
# MILVUS_COLLECTION_PREFIX=finance_tweet
# MILVUS_TIMEOUT_SEC=30

# ----- DashScope (embedding + rerank) -----
DASHSCOPE_API_KEY=sk-your-dashscope-key

# ----- JWT Auth -----
JWT_SECRET_KEY=generate-a-random-secret-here
ADMIN_USER_IDS=[]
MAX_FOLLOWED_BLOGGERS_PER_USER=20
USER_ANALYSIS_REQUESTS_ENABLED=false
USER_ANALYSIS_DAILY_LIMIT=10
USER_ANALYSIS_PIPELINE_VERSION=v1
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# ----- Twitter API -----
TWITTER_AUTH_TOKEN=your_twitter_auth_token
TWITTER_CT0=your_twitter_ct0_csrf_token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ----- Storage -----
DOCUMENT_STORAGE_ROOT=./uploads

# ----- Feature flag -----
FEATURE_RAG_ENABLED=true

# ----- Debug -----
DEBUG_MODE=false
LOG_JSON=false
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false
