# ============================================================
# Finance Tweet Analyzer — 环境变量模板
# ============================================================
# 复制本文件为 .env 并填入真实值：
#   cp .env.example .env
#
# 所有敏感信息（密钥、密码、Token）必须且只能通过 .env 注入，
# 代码中不包含任何硬编码凭据。
# ============================================================

# ----- Database -----
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/finance_tweets

# ----- OpenRouter LLM -----
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HTTP_PROXY=

# ----- Models -----
SIGNAL_MODEL=qwen/qwen3.7-plus
REPORT_MODEL=qwen/qwen3.7-max

# ----- LangSmith (optional) -----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finance-tweet-analyzer
LANGSMITH_TRACING=false

# ----- Scheduler -----
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=10

# ----- Redis & Celery -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_PREDICTION_INTERVAL_MINUTES=5

# ----- RAG / Vector store -----
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma_db

# ----- DashScope (embedding + rerank) -----
DASHSCOPE_API_KEY=sk-your-dashscope-key

# ----- JWT Auth -----
JWT_SECRET_KEY=generate-a-random-secret-here

# ----- Twitter API -----
TWITTER_AUTH_TOKEN=your_twitter_auth_token
TWITTER_CT0=your_twitter_ct0_csrf_token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ----- Storage -----
DOCUMENT_STORAGE_ROOT=./uploads

# ----- Feature flag -----
FEATURE_RAG_ENABLED=true

# ----- Debug -----
DEBUG_MODE=false
LOG_JSON=false
